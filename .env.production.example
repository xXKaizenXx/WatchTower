# Copy to .env before: docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d

ENVIRONMENT=production
DEBUG=false

# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
WATCHTOWER_API_KEY=

# Your public API URL host(s), comma-separated
TRUSTED_HOSTS=watchtower.example.com,api.watchtower.example.com
CORS_ORIGINS=https://watchtower.example.com

# Set false to hide /docs in production (default: hidden when ENVIRONMENT=production)
# ENABLE_DOCS=false

DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/watchtower
DATABASE_URL_SYNC=postgresql+psycopg2://user:pass@host:5432/watchtower
REDIS_URL=redis://:password@host:6379/0
CELERY_BROKER_URL=redis://:password@host:6379/1
CELERY_RESULT_BACKEND=redis://:password@host:6379/2

SLACK_WEBHOOK_URL=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_ALERT_NUMBER=

PING_RATE_LIMIT=120/minute
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
